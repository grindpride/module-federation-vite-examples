  "scripts": {
    "prepare": "husky install",
    "fmt": "oxfmt *",
    "fmt.check": "oxfmt --check *",
    "deps:unpin": "node -e \"const { readdirSync, readFileSync, writeFileSync } = require('node:fs'); const { join } = require('node:path'); const walk = (dir) => { for (const entry of readdirSync(dir, { withFileTypes: true })) { if (entry.name === '.git' || entry.name === 'node_modules') continue; const path = join(dir, entry.name); if (entry.isDirectory()) walk(path); else if (entry.name === 'package.json') { const text = readFileSync(path, 'utf8'); const next = text.replace(/\\\": \\\"[\\^*~]/g, '\\\": \\\"'); if (next !== text) writeFileSync(path, next); } } }; walk(process.cwd());\"",
    "alpine:build": "pnpm -C alpine build",
    "alpine:dev": "pnpm -C alpine dev",
    "alpine:preview": "pnpm -C alpine preview",
    "angular:build": "pnpm -C angular build",
    "angular:dev": "pnpm -C angular dev",
    "angular:preview": "pnpm -C angular preview",
    "lit:build": "pnpm -C lit build",
    "lit:dev": "pnpm -C lit dev",
    "lit:preview": "pnpm -C lit preview",
    "nuxt:build": "pnpm -C nuxt build",
    "nuxt:dev": "pnpm -C nuxt dev",
    "nuxt:preview": "pnpm -C nuxt preview",
    "preact:build": "pnpm -C preact build",
    "preact:dev": "pnpm -C preact dev",
    "preact:preview": "pnpm -C preact preview",
    "react:build": "pnpm -C react build",
    "react:dev": "pnpm -C react dev",
    "react:preview": "pnpm -C react preview",
    "solid:build": "pnpm -C solid build",
    "solid:dev": "pnpm -C solid dev",
    "solid:preview": "pnpm -C solid preview",
    "svelte:build": "pnpm -C svelte build",
    "svelte:dev": "pnpm -C svelte dev",
    "svelte:preview": "pnpm -C svelte preview",
    "tanstack:build": "pnpm -C tanstack build",
    "tanstack:dev": "pnpm -C tanstack dev",
    "tanstack:preview": "pnpm -C tanstack preview",
    "vinext:build": "pnpm -C vinext build",
    "vinext:dev": "pnpm -C vinext dev",
    "vinext:preview": "pnpm -C vinext preview",
    "vue:build": "pnpm -C vue build",
    "vue:dev": "pnpm -C vue dev",
    "vue:preview": "pnpm -C vue preview"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "husky": "9.1.7",
    "oxfmt": "0.36.0"
  }
}
